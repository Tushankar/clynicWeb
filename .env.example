# ====================================================================================
#  clinic-web — environment (copy to .env and fill in). Only VITE_* vars reach the browser,
#  so NEVER put secrets here (no secret keys — publishable/public values only).
# ====================================================================================

# ---- API + realtime ----
VITE_API_BASE_URL=http://localhost:5000     # clinic-api base URL
VITE_SOCKET_URL=http://localhost:5000       # Socket.IO endpoint (live queue); defaults to the API URL

# ---- Clerk (Phase 0) — https://dashboard.clerk.com → API Keys ----
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx      # PUBLISHABLE key only (same one as the backend)

# ---- Optional / future ----
# VITE_APP_URL=http://localhost:5173        # this app's own URL (currently derived from the browser)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxx         # not required — Razorpay Checkout gets the key id from the server order
