# ====================================================================================
#  clinic-web — LOCAL .env (gitignored). Only VITE_* vars reach the browser — NO secrets.
#  Replace VITE_CLERK_PUBLISHABLE_KEY with your real publishable key (the app needs it to boot).
# ====================================================================================

# ---- API + realtime ----
VITE_API_BASE_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ---- Clerk (publishable key only — same one as the backend) ----
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YWR2YW5jZWQtY3ViLTYuY2xlcmsuYWNjb3VudHMuZGV2JA

# ---- Public website (§5.19): flagship clinic shown at the root "/" ----
VITE_MAIN_SITE_SLUG=clynic

